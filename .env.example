# =============================================================================
# IELTS CBT AI — Development Environment Template
# Copy to .env and run: php artisan key:generate && php artisan migrate
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="IELTS CBT AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ielts_cbt
DB_USERNAME=root
DB_PASSWORD=

# ── Redis ───────────────────────────────────────────────────────────────────
# Uses predis (pure PHP) — no phpredis extension required on Windows.
# Start Redis locally (Docker: redis:7-alpine, or Memurai on Windows).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Cache & Session ───────────────────────────────────────────────────────────
# Quick start (no Redis required — use these until Redis is running):
CACHE_STORE=file
SESSION_DRIVER=file

# Full stack (uncomment when Redis is running on port 6379):
# CACHE_STORE=redis
# SESSION_DRIVER=redis
CACHE_PREFIX=ielts_cbt_

SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Queue ─────────────────────────────────────────────────────────────────────
# Quick start: sync runs jobs immediately (no worker needed)
QUEUE_CONNECTION=sync

# Full stack (uncomment when Redis is running):
# QUEUE_CONNECTION=redis
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=90

# ── Listening Audio Pipeline / FFmpeg ─────────────────────────────────────────
# Install FFmpeg and ensure ffmpeg/ffprobe are in PATH, or point these to full paths:
# FFMPEG_BINARY="C:\ffmpeg\bin\ffmpeg.exe"
# FFPROBE_BINARY="C:\ffmpeg\bin\ffprobe.exe"
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
LISTENING_AUDIO_QUEUE=listening-audio
# Do not use sync — FFmpeg processing exceeds PHP max_execution_time in web requests.
LISTENING_AUDIO_QUEUE_CONNECTION=database

# ── Mail ──────────────────────────────────────────────────────────────────────
# Local options:
#   log     — writes emails to storage/logs/laravel.log (zero setup)
#   smtp    — use Mailtrap (below) or Mailpit on port 1025
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@ielts-cbt.test"
MAIL_FROM_NAME="${APP_NAME}"

# ── Storage ───────────────────────────────────────────────────────────────────
# local = storage/app/private (default private disk)
# public = storage/app/public (requires php artisan storage:link)
# s3 = AWS S3 (fill AWS_* vars below for production)
FILESYSTEM_DISK=local

# ── AWS S3 (production / optional local testing) ──────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Broadcasting ──────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Logging ───────────────────────────────────────────────────────────────────
# stack → daily + single channels (see config/logging.php)
LOG_CHANNEL=stack
LOG_STACK=daily,single
LOG_LEVEL=debug
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false

# ── Horizon (Queue Dashboard) ─────────────────────────────────────────────────
# Requires pcntl/posix — runs on Linux/macOS/WSL. On Windows use queue:listen.
HORIZON_NAME="${APP_NAME}"
HORIZON_DOMAIN=
HORIZON_PATH=horizon
HORIZON_PREFIX=ielts_cbt_horizon:

# ── Telescope (Request / Job Debugger) ────────────────────────────────────────
# Dev-only. Disabled automatically in tests via phpunit.xml.
TELESCOPE_ENABLED=true
TELESCOPE_DOMAIN=
TELESCOPE_PATH=telescope
TELESCOPE_DRIVER=database

# ── Debugbar (Browser Debug Panel) ────────────────────────────────────────────
# null = auto (enabled when APP_DEBUG=true). Set false to disable explicitly.
DEBUGBAR_ENABLED=
DEBUGBAR_COLLECT_JOBS=true

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
